# Neon PostgreSQL connection string (from Neon dashboard)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD_HERE@YOUR_POOL_ENDPOINT/neondb?sslmode=require&channel_binding=require

# JWT secret for session tokens (change this to something random)
JWT_SECRET=carebridge-secret-key-change-in-production-use-random-string

# Server port (Vercel sets this automatically)
PORT=3000
