{
  "rewrites": [
    { "source": "/patient-portal", "destination": "/Patient Portal.html" },
    { "source": "/portal",         "destination": "/Carebridge Portal.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" }
      ]
    }
  ]
}
